for i,v in next, workspace.Map["obstacle/puzzles"].CastleIsland.Hexa_Path:GetChildren() do
if v and v:IsA("BasePart") then
v.Size = Vector3.new(100,1,100)
end
end
repeat task.wait(.2)
for _,location in next, workspace.Map.GloveLocation:GetChildren() do
if location then
print("Scanning location ("..location.Name..")")
Character:PivotTo(location:FindFirstChildWhichIsA("BasePart",true).CFrame)
task.wait(5)
for _,glove in next, location:GetChildren() do
if glove then
print("Trying to get "..glove.Name.." glove")
if (glove:GetAttribute("Solved")~=nil and glove:GetAttribute("Solved")==false) and glove:GetAttribute("Visible")==false then
glove:SetAttribute("Solved",true)
task.wait(1)
TouchObject(glove:GetChildren()[1], 2)
elseif (glove:GetAttribute("Solved")==nil or glove:GetAttribute("Solved")==true) and glove:GetAttribute("Visible")==true then
TouchObject(glove:GetChildren()[1], 2)
else
print("Skipping glove "..glove.Name..". Solved | Visible", glove:GetAttribute("Solved"), glove:GetAttribute("Visible"))
continue
end
end
end
end
end
until game:GetService("BadgeService"):UserHasBadgeAsync(LocalPlayer.UserId, 1902849233175110)]])
end; })

