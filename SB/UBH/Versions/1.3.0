if RNG_Method=="Slap 5 More" then
local slappingdone = false
EquipGlove("5 More")
HumanoidRootPart:PivotTo(CFrame.new(17891,-23.8,-3517))
task.wait(1)
HumanoidRootPart.Anchored = true
task.wait(.5)
for i=1,2 do
game:GetService("ReplicatedStorage").Events.slasher2:FireServer(true)
task.wait()
end
task.wait(.5)
for i=1,6 do
game.ReplicatedStorage.GeneralAbility:FireServer()
task.wait(1.33)
end
EquipGlove("Dice")
repeat task.wait(.6)
for i,v in next, workspace[LocalPlayer.Name.."_More"]:GetChildren() do
game.ReplicatedStorage.DiceHit:FireServer(v.HumanoidRootPart)
task.wait()
end
until game:GetService("BadgeService"):UserHasBadgeAsync(LocalPlayer.UserId, 2130031244) or Humanoid.Health==0
slappingdone = true
elseif RNG_Method=="Slap Replica" then
local slappingdone = false
HumanoidRootPart:PivotTo(CFrame.new(17891,-23.8,-3517))
task.wait(1)
HumanoidRootPart.Anchored = true
task.wait(.5)
for i=1,2 do
game:GetService("ReplicatedStorage").Events.slasher2:FireServer(true)
task.wait()
end
task.wait(.5)
repeat task.wait(.6)
if not workspace:FindFirstChild("Å"..LocalPlayer.Name) then
EquipGlove("Replica")
game.ReplicatedStorage.Duplicate:FireServer(true)
EquipGlove("Dice")
repeat task.wait() until workspace:FindFirstChild("Å"..LocalPlayer.Name)
end
game.ReplicatedStorage.DiceHit:FireServer(workspace["Å"..LocalPlayer.Name]:WaitForChild("HumanoidRootPart"))
until game:GetService("BadgeService"):UserHasBadgeAsync(LocalPlayer.UserId, 2130031244) or Humanoid.Health==0
slappingdone = true
elseif RNG_Method=="Slap People" then
EquipGlove("Ghost")
game.ReplicatedStorage.Ghostinvisibilityactivated:FireServer()
task.wait(.5)
EquipGlove("Dice")
local vector = Vector3.new(0,0,0)
repeat task.wait()
local rp = FindRandomPlayer()
for i=1,100 do
HumanoidRootPart:PivotTo(rp:WaitForChild("HumanoidRootPart").CFrame)
for _,p in next, Character:GetDescendants() do
if p:IsA("BasePart") then
p.Velocity, p.RotVelocity = vector, vector
end
end
task.wait(.005)
end
game.ReplicatedStorage.DiceHit:FireServer(rp:WaitForChild("HumanoidRootPart"))
for i=1,100 do
HumanoidRootPart:PivotTo(rp:WaitForChild("HumanoidRootPart").CFrame)
for _,p in next, Character:GetDescendants() do
if p:IsA("BasePart") then
p.Velocity, p.RotVelocity = vector, vector
end
end
task.wait(.005)
end
until game:GetService("BadgeService"):UserHasBadgeAsync(LocalPlayer.UserId, 2130031244) or Humanoid.Health==0
end
task.wait(1)
Humanoid.Health = 0
a:Destroy()
end; })

