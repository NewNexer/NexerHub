for i,v in pairs(workspace:GetChildren()) do
if v.Name:match(LocalPlayer.Name) and v:FindFirstChild("VehicleSeat") then
pcall(function()
repeat task.wait()
HumanoidRootPart:PivotTo(v.VehicleSeat.CFrame)
until Humanoid.Sit==true
end)
end
end
end
