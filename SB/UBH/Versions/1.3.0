AutoObtainment:CreateButton({Name = "Auto-Get Bomb ( Requires Warp )"; Callback = function()
if not HumanoidRootPart or not Humanoid then return end
if Character:FindFirstChild("entered") then Rayfield:Notification("Error!","Use in lobby!",3,false) end
local a = CreateMessage()
a.Text = "Getting Bomb..."
EquipGlove("Ghost")
game.ReplicatedStorage.Ghostinvisibilityactivated:FireServer()
task.wait(.5)
EquipGlove("Warp")
local vector = Vector3.new(0,0,0)
local rp = FindRandomPlayer()
for i=1,150 do
HumanoidRootPart:PivotTo(rp:WaitForChild("HumanoidRootPart").CFrame)
for _,p in next, Character:GetDescendants() do
if p:IsA("BasePart") then
p.Velocity, p.RotVelocity = vector, vector
end
end
task.wait(.005)
end
game.ReplicatedStorage.WarpHt:FireServer(rp:WaitForChild("HumanoidRootPart"),true)
for i=1,150 do
HumanoidRootPart:PivotTo(rp:WaitForChild("HumanoidRootPart").CFrame)
for _,p in next, Character:GetDescendants() do
if p:IsA("BasePart") then
p.Velocity, p.RotVelocity = vector, vector
end
end
task.wait(.005)
end
HumanoidRootPart:PivotTo(workspace.DEATHBARRIER.CFrame)
task.wait(.1)
game:GetService("ReplicatedStorage").WLOC:FireServer()
a:Destroy()
end; })

